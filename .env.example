SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=your_warehouse

# Optional
SNOWFLAKE_ROLE=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Set exactly one private key source:
# 1) Recommended for portability: Base64-encoded PEM content
SNOWFLAKE_PRIVATE_KEY_B64=

# 2) Or raw PEM key content (single-line with escaped newlines)
# SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 3) Or path to a .p8 key file (absolute or repo-relative)
# SNOWFLAKE_PRIVATE_KEY_PATH=keys/rsa_key.p8
